{
  "name": "emporix-companies-module",
  "private": true,
  "version": "0.0.0",
  "license": "GPL-3.0",
  "description": "Emporix Management Dashboard federation remote — companies (legal entities) module",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:prod": "vite --mode prod",
    "dev:stage": "vite --mode stage",
    "build:watch": "tsc -b && vite build --mode dev --watch",
    "build:dev": "tsc -b && vite build",
    "build:stage": "tsc -b && vite build --mode stage",
    "build:prod": "tsc -b && vite build --mode prod",
    "build:prod:watch": "tsc -b && vite build --mode prod --watch",
    "lint": "eslint .",
    "preview": "vite preview",
    "serve:prod": "yarn build:prod && vite preview",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@originjs/vite-plugin-federation": "^1.3.9",
    "axios": "^1.16.0",
    "axios-retry": "^3.3.1",
    "classnames": "^2.3.1",
    "i18next": "^23.16.0",
    "primeflex": "^3.1.3",
    "primeicons": "^6.0.0",
    "primereact": "^8.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^11.16.7",
    "react-icons": "^4.3.1",
    "react-router-dom": "^6.3.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/i18next": "^13.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^9.0.1",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "prettier": "3.5.0",
    "sass": "^1.99.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.6"
  }
}
