{
  "name": "@emporix/dashboard-extension",
  "private": false,
  "version": "1.0.0",
  "description": "Emporix Dashboard Extension Module",
  "author": "Emporix",
  "keywords": [
    "emporix",
    "dashboard",
    "federation",
    "extension"
  ],
  "engines": {
    "node": ">=18.18.0",
    "npm": ">=9.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:stage": "vite --mode stage",
    "build:watch": "tsc -b && vite build --mode dev --watch",
    "build:dev": "tsc -b && vite build --mode dev",
    "build:stage": "tsc -b && vite build --mode stage",
    "build:prod": "tsc -b && vite build --mode prod",
    "build": "tsc -b && vite build --mode prod",
    "lint": "eslint .",
    "test:run": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@originjs/vite-plugin-federation": "^1.3.9",
    "@types/papaparse": "^5.5.0",
    "chart.js": "^4.4.0",
    "papaparse": "^5.5.3",
    "primeflex": "^3.1.3",
    "primeicons": "^6.0.0",
    "primereact": "^8.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^2.2.2",
    "react-simple-maps": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "prettier": "3.5.0",
    "sass": "^1.69.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "vitest": "^4.0.18"
  }
}
